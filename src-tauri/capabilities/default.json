{
  "identifier": "default",
  "description": "Default capabilities for SSH Editor",
  "windows": ["main", "win-*"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:event:allow-emit",
    "store:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}
