{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SSH Editor",
  "version": "0.1.0",
  "identifier": "io.rinjae.ssh-editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SSH Editor",
        "width": 1400,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
